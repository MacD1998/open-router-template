# Copy this file to ".env" and fill in your key.
#
# Get an API key at: https://openrouter.ai/keys
# (Sign in, create a key, it looks like "sk-or-v1-...")
OPENROUTER_API_KEY=sk-or-...

# Which model the sample calls run against.
# Must be a real, currently-listed OpenRouter model slug ("author/slug").
# Browse the catalog at https://openrouter.ai/models — Phase 1 of main.py
# also prints a sample of the live catalog with prices.
#
# Default is a cheap, fast, multi-provider model (good for showing real
# cost accounting and provider fallback). Swap freely, e.g.:
#   google/gemini-2.5-flash-lite
#   deepseek/deepseek-chat-v3.1
#   mistralai/mistral-nemo
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
